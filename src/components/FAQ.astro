---
import { ChevronDown } from 'lucide-react';

const FAQS = [
    { q: "Apakah layanan Ocha gratis?", a: "Ya. Ocha tidak mengenakan biaya layanan kepada pasien. Ocha didukung melalui kemitraan yang diungkapkan dengan rumah sakit, dan pembayaran medis dilakukan langsung kepada rumah sakit." },
    { q: "Bagaimana cara membuat janji?", a: "Pilih kebutuhan dan ajukan jadwal konsultasi. Tim Ocha akan meninjau pilihan, memeriksa ketersediaan, lalu menghubungi Anda melalui WhatsApp." },
    { q: "Apakah jadwal yang saya pilih langsung dikonfirmasi?", a: "Belum. Jadwal yang dipilih merupakan permintaan dan baru dikonfirmasi setelah tim Ocha memeriksa ketersediaan dokter atau rumah sakit." },
    { q: "Apakah Ocha memberikan diagnosis atau saran pengobatan?", a: "Tidak. Ocha membantu menghubungkan pasien dengan dokter dan rumah sakit mitra. Diagnosis dan keputusan pengobatan harus diberikan oleh tenaga medis yang berkualifikasi." }
];
---

<section class="py-24 bg-white">
  <div class="max-w-3xl mx-auto px-6">
      <h2 class="font-serif text-3xl font-medium text-slate-900 text-center mb-12">Pertanyaan yang Sering Diajukan</h2>
      <div class="space-y-4">
          {FAQS.map((faq) => (
              <details class="group bg-slate-50 rounded-xl border border-slate-100 open:bg-white open:shadow-sm transition-all duration-300">
                  <summary class="flex justify-between items-center cursor-pointer p-6 list-none text-slate-900 font-medium text-lg">
                      {faq.q}
                      <span class="transform group-open:rotate-180 transition-transform duration-300 text-slate-400">
                          <ChevronDown className="w-5 h-5" />
                      </span>
                  </summary>
                  <div class="px-6 pb-6 text-slate-500 leading-relaxed animate-fade-in">
                      {faq.a}
                  </div>
              </details>
          ))}
      </div>
  </div>
</section>

<style>
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(-5px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in {
    animation: fadeIn 0.3s ease-out forwards;
  }
</style>
