---
// src/pages/doctors.astro
import LandingLayout from '../layouts/LandingLayout.astro'; // 👈 Switched to LandingLayout (Has Navbar/Footer)
import Directory from '../components/Directory.jsx';
import { GOOGLE_SHEET_URL } from '../config';

// 🚀 FETCH DATA AT BUILD TIME (SERVER-SIDE)
let allDoctors = [];
try {
  const noCacheUrl = `${GOOGLE_SHEET_URL}?t=${Date.now()}`;
  const response = await fetch(noCacheUrl, { cache: 'no-store' });
  if (!response.ok) throw new Error(`HTTP ${response.status}`);
  const rawData = await response.json();

  // 🛡️ BULLETPROOF FILTER & DEDUPLICATOR
  // 1. Remove any blank/empty rows
  const validDoctors = rawData.filter(doc => doc.name && doc.id);
  
  // 2. Deduplicate exact IDs, then reject normalized ID collisions.
  allDoctors = Array.from(new Map(validDoctors.map(doc => [String(doc.id), doc])).values());
  const normalizedIds = allDoctors.map(doc => String(doc.id).trim().toLowerCase());
  if (new Set(normalizedIds).size !== normalizedIds.length) {
    throw new Error('Duplicate doctor IDs remain after normalization');
  }

  console.log(`✅ Fetched ${allDoctors.length} unique doctors at ${new Date().toLocaleTimeString()}`);
} catch (error) {
  throw new Error(`Doctor data fetch failed: ${error instanceof Error ? error.message : String(error)}`);
}
---

<LandingLayout 
  title="Cari Dokter Spesialis di Malaysia | Ocha Healthcare"
  description="Jelajahi dokter spesialis dalam jaringan mitra terverifikasi Ocha di Malaysia. Cari berdasarkan lokasi, rumah sakit, dan spesialisasi."
>
  
  {/* Background Texture */}
  <div class="absolute inset-0 bg-[url('https://grainy-gradients.vercel.app/noise.svg')] opacity-20 pointer-events-none z-0"></div>

  {/* 🚀 FIXED: Added 'overflow-x-hidden' to kill the white gap on the right */}
  <main class="relative min-h-screen pt-32 pb-20 overflow-x-hidden">
    
    {/* === PAGE HEADER === */}
    <div class="max-w-4xl mx-auto px-6 text-center mb-12 relative z-10">
        <span class="inline-block py-1 px-3 rounded-full bg-blue-50 border border-blue-100 text-[#276CA1] text-xs font-bold uppercase tracking-wider mb-6">
          Direktori
        </span>
        <h1 class="font-serif text-4xl md:text-5xl text-slate-900 mb-6 leading-tight">
          Cari Dokter Spesialis Terverifikasi
        </h1>
        <p class="text-lg text-slate-500 max-w-2xl mx-auto leading-relaxed">
          Cari dokter dalam jaringan rumah sakit mitra Ocha di Malaysia berdasarkan
          spesialisasi, lokasi, rumah sakit, atau nama.
        </p>
    </div>

    {/* === DIRECTORY COMPONENT === */}
    <section id="directory" class="max-w-7xl mx-auto px-4 sm:px-6 relative z-10">
        <Directory client:load preloadedDoctors={allDoctors} pageType="doctor_directory" />
    </section>

  </main>
</LandingLayout>
