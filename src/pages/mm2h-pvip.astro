---
// src/pages/mm2h-pvip.astro
// Malaysia MM2H & PVIP long-term stay support — in partnership with Daro International
import LandingLayout from '../layouts/LandingLayout.astro';
import { WA_NUMBER } from '../config';
import {
  ShieldCheck, HeartPulse, GraduationCap, Home, Wallet, Globe,
  Building2, Users, CheckCircle2, MessageCircle, Plane, Briefcase,
  FileText, ArrowRight, Sparkles, Landmark
} from 'lucide-react';

const pageTitle = 'MM2H & PVIP Malaysia Long-Term Stay Visa Support | Ocha Healthcare';
const pageDesc = 'Explore Malaysia My Second Home (MM2H) and the Premium Visa Programme (PVIP) with Ocha Healthcare and licensed advisor Daro International. Eligibility, requirements, application process and expert guidance for retirement, family relocation, healthcare and investment.';

const waBase = `https://wa.me/${WA_NUMBER}?text=`;
const waGeneral = waBase + encodeURIComponent("Hi Ocha, I'd like to learn more about long-term stay in Malaysia (MM2H / PVIP) with Daro International. Please share the details.");
const waMM2H = waBase + encodeURIComponent("Hi Ocha, I'm interested in the Malaysia My Second Home (MM2H) programme. Please help me with a consultation.");
const waPVIP = waBase + encodeURIComponent("Hi Ocha, I'm interested in the Malaysia Premium Visa Programme (PVIP). Please help me with a consultation.");

const whyMalaysia = [
  { icon: ShieldCheck, title: 'Stability & Security', desc: 'A safe, peaceful and stable environment for long-term living.' },
  { icon: Wallet, title: 'Affordable Cost of Living', desc: 'Enjoy a high quality of life at a lower cost.' },
  { icon: HeartPulse, title: 'World-Class Healthcare', desc: 'Access modern private hospitals and specialist doctors.' },
  { icon: GraduationCap, title: 'Quality Education', desc: 'International schools and globally recognised universities.' },
  { icon: Home, title: 'Property Ownership', desc: 'Foreigners can purchase property in a regulated market.' },
  { icon: Building2, title: 'Modern Infrastructure', desc: 'Reliable transport, connectivity and digital services.' },
  { icon: Users, title: 'People & Culture', desc: 'Friendly, multicultural communities with English widely spoken.' },
  { icon: Globe, title: 'Regional Connectivity', desc: 'A central Southeast Asian base for easy travel and mobility.' },
];

const mm2hBenefits = [
  '5–20 year renewable multiple-entry visa',
  'Family-friendly — bring approved dependents',
  'Access to healthcare & education',
  'Flexible property ownership options',
  'Retain your nationality & home benefits',
];
const mm2hReqs = ['Age eligibility', 'Fixed deposit', 'Property purchase', 'Medical check-up', 'Medical insurance', 'Relationship proof', 'Income proof'];

const pvipBenefits = [
  '20-year renewable multiple-entry visa',
  'Family-friendly — include your dependents',
  'Healthcare, education & property access',
  'Allowed to work & conduct business',
  'No minimum stay requirement',
];
const pvipReqs = ['Participation fee', 'Fixed deposit', 'Income proof', 'Medical check-up', 'Medical insurance', 'Relationship proof'];

const steps = [
  { n: '01', title: 'Consultation & Eligibility Review', desc: 'We assess your motivation and outline an application strategy.', note: 'Typically takes a few days.' },
  { n: '02', title: 'Document Review & Submission', desc: 'We compile and review your documents, then submit the application.', note: 'Timeline depends on client readiness and document completeness.' },
  { n: '03', title: 'Official Review', desc: 'The authority assesses the application and may request additional information.', note: 'Processing time varies and approval is not guaranteed.' },
  { n: '04', title: 'Endorsement', desc: 'We assist with conditional approval requirements and the visa endorsement process.', note: 'Typically completed within 2 weeks, subject to readiness.' },
];

const comparison = [
  { label: 'Best suited for', mm2h: 'Retirees & families', pvip: 'Investors, entrepreneurs & business owners' },
  { label: 'Visa length', mm2h: '5–20 years, renewable', pvip: '20 years, renewable' },
  { label: 'Minimum stay', mm2h: 'Stay conditions may apply', pvip: 'No minimum stay requirement' },
  { label: 'Work & business', mm2h: 'Focused on residency & lifestyle', pvip: 'Allowed to work & conduct business' },
  { label: 'Primary goal', mm2h: 'Retirement, family settlement, healthcare', pvip: 'Business, investment, mobility' },
];

const daroPillars = [
  { icon: Sparkles, title: 'Personalised Guidance', items: ['Dedicated consultant', 'Tailored application strategy', 'End-to-end application support'] },
  { icon: HeartPulse, title: 'Family & Lifestyle Support', items: ['Leading schools & universities', 'World-class private hospitals'] },
  { icon: Plane, title: 'Arrival, Endorsement & Settlement', items: ['Transportation coordination', 'Banking & insurance guidance', 'Healthcare arrangements'] },
  { icon: Briefcase, title: 'Business Network Access', items: ['Network of corporate advisors', 'Business & investment connections'] },
];

const daroSupport = [
  'MM2H and PVIP eligibility assessment',
  'Programme comparison and application strategy',
  'Personalised document checklist',
  'Application preparation and submission coordination',
  'Follow-up with relevant authorities',
  'Bank account, fixed deposit, medical check-up and insurance guidance',
  'Visa endorsement and post-approval settlement support',
];

const faqs = [
  { q: 'What is Malaysia My Second Home (MM2H)?', a: 'MM2H is a long-term stay programme for eligible foreigners who wish to live in Malaysia for an extended period. It is commonly suitable for retirees, families and individuals who want Malaysia as a second home, with access to healthcare, education and lifestyle facilities.' },
  { q: 'What is the Premium Visa Programme (PVIP)?', a: 'PVIP is Malaysia’s premium long-term visa for qualified high-net-worth individuals, entrepreneurs, investors and global citizens who want greater flexibility to live, work and invest in Malaysia, with no minimum stay requirement.' },
  { q: 'Which is right for me — MM2H or PVIP?', a: 'The right programme depends on your purpose, financial profile, family structure, property plans and long-term goals. MM2H suits retirement, family settlement and healthcare access, while PVIP suits business, investment and work flexibility. A consultation with Daro International helps you choose.' },
  { q: 'Can I include my family?', a: 'Yes. Both MM2H and PVIP offer family-friendly options that allow eligible applicants to include approved dependents, subject to the applicable rules.' },
  { q: 'Does Ocha handle the visa application?', a: 'Ocha supports your healthcare journey in Malaysia and connects you with Daro International, a licensed long-term stay advisory firm, for MM2H and PVIP application guidance and coordination.' },
  { q: 'Is approval guaranteed?', a: 'No. Programme requirements may change from time to time and approval is subject to the relevant Malaysian authorities. Applicants should obtain updated advice based on their personal circumstances before making any decision.' },
];

// 🔎 Structured data
const canonical = new URL('/mm2h-pvip', Astro.site).href;
const faqالسchema = null;
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": pageTitle,
    "description": pageDesc,
    "url": canonical,
    "inLanguage": "en",
    "isPartOf": { "@type": "WebSite", "name": "Ocha Healthcare", "url": "https://ocha.health" }
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "serviceType": "Malaysia long-term stay visa advisory (MM2H & PVIP)",
    "name": "Malaysia MM2H & PVIP Long-Term Stay Support",
    "description": pageDesc,
    "areaServed": "Malaysia",
    "provider": { "@type": "Organization", "name": "Ocha Healthcare", "url": "https://ocha.health" },
    "offers": [
      { "@type": "Offer", "name": "Malaysia My Second Home (MM2H)" },
      { "@type": "Offer", "name": "Premium Visa Programme (PVIP)" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a }
    }))
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://ocha.health" },
      { "@type": "ListItem", "position": 2, "name": "MM2H & PVIP", "item": canonical }
    ]
  }
];
---

<LandingLayout title={pageTitle} description={pageDesc}>
  <main class="overflow-x-hidden">

    {/* ============ HERO ============ */}
    <section class="relative isolate overflow-hidden bg-gradient-to-b from-white to-slate-50">
      <div class="absolute top-0 right-0 w-[520px] h-[520px] bg-amber-100/40 rounded-full blur-3xl -z-10 translate-x-1/3 -translate-y-1/4"></div>
      <div class="absolute bottom-0 left-0 w-[520px] h-[520px] bg-indigo-100/50 rounded-full blur-3xl -z-10 -translate-x-1/3"></div>

      <div class="max-w-6xl mx-auto px-6 py-16 md:py-24 text-center">
        <span class="inline-flex items-center gap-2 py-1.5 px-4 rounded-full bg-amber-50 text-amber-700 text-[11px] font-extrabold uppercase tracking-wider mb-5 border border-amber-200 shadow-sm">
          <Landmark className="w-3.5 h-3.5" /> In partnership with Daro International
        </span>
        <h1 class="font-serif text-4xl md:text-6xl font-bold text-slate-900 leading-tight mb-6">
          Make Malaysia Your <span class="text-[#276CA1]">Second Home</span>
        </h1>
        <p class="text-lg md:text-xl text-slate-600 max-w-3xl mx-auto leading-relaxed mb-4">
          Long-term stay support for healthcare, retirement, family relocation and investment — through the <strong class="text-slate-800">MM2H</strong> and <strong class="text-slate-800">Premium Visa (PVIP)</strong> programmes.
        </p>
        <p class="text-base text-slate-500 max-w-2xl mx-auto mb-9">
          Ocha guides your medical journey in Malaysia; licensed advisor Daro International guides your long-term stay.
        </p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a href={waGeneral} target="_blank" rel="noopener" class="inline-flex items-center justify-center gap-2 bg-[#276CA1] text-white px-7 py-3.5 rounded-full text-sm font-bold hover:bg-[#1f5682] transition shadow-lg shadow-blue-900/20 active:scale-95">
            <MessageCircle className="w-4 h-4" /> Book a Free Consultation
          </a>
          <a href="#compare" class="inline-flex items-center justify-center gap-2 bg-white text-slate-700 px-7 py-3.5 rounded-full text-sm font-bold border border-slate-200 hover:border-amber-300 hover:text-amber-700 transition active:scale-95">
            Compare MM2H vs PVIP <ArrowRight className="w-4 h-4" />
          </a>
        </div>
      </div>
    </section>

    {/* ============ WHY MALAYSIA ============ */}
    <section class="py-16 md:py-20">
      <div class="max-w-6xl mx-auto px-6">
        <div class="text-center max-w-2xl mx-auto mb-12">
          <h2 class="font-serif text-3xl md:text-4xl font-bold text-slate-900 mb-4">Why Malaysia?</h2>
          <p class="text-slate-600 leading-relaxed">Moving to a new country is a big decision. With its welcoming culture, tropical lifestyle and everyday convenience, Malaysia offers many reasons to call it home.</p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
          {whyMalaysia.map((f) => (
            <div class="bg-white rounded-2xl border border-slate-100 p-6 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all">
              <div class="w-11 h-11 rounded-xl bg-blue-50 text-[#276CA1] flex items-center justify-center mb-4">
                <f.icon className="w-5 h-5" />
              </div>
              <h3 class="font-bold text-slate-900 mb-1.5">{f.title}</h3>
              <p class="text-sm text-slate-500 leading-relaxed">{f.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ============ MM2H ============ */}
    <section id="mm2h" class="py-16 md:py-20 bg-white border-y border-slate-100">
      <div class="max-w-6xl mx-auto px-6">
        <div class="grid lg:grid-cols-2 gap-12 items-start">
          <div>
            <span class="inline-block py-1 px-3 rounded-full bg-blue-50 text-[#276CA1] text-[11px] font-extrabold uppercase tracking-wider mb-4 border border-blue-100">Programme 1</span>
            <h2 class="font-serif text-3xl md:text-4xl font-bold text-slate-900 mb-4">Malaysia My Second Home <span class="text-[#276CA1]">(MM2H)</span></h2>
            <p class="text-slate-600 leading-relaxed mb-6">A long-term stay programme for foreigners and their families who wish to live, retire, study or spend extended time in Malaysia. Commonly suitable for retirees, families and those focused on healthcare access and lifestyle planning.</p>
            <h3 class="font-bold text-slate-900 mb-3">Key benefits</h3>
            <ul class="space-y-2.5 mb-6">
              {mm2hBenefits.map((b) => (
                <li class="flex items-start gap-3 text-slate-700"><CheckCircle2 className="w-5 h-5 text-[#276CA1] flex-shrink-0 mt-0.5" /><span>{b}</span></li>
              ))}
            </ul>
            <a href={waMM2H} target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-[#276CA1] font-bold text-sm hover:gap-3 transition-all">Ask about MM2H <ArrowRight className="w-4 h-4" /></a>
          </div>
          <div class="bg-slate-50 rounded-2xl border border-slate-100 p-7">
            <h3 class="font-bold text-slate-900 mb-4 flex items-center gap-2"><FileText className="w-5 h-5 text-[#276CA1]" /> Requirements</h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-3">
              {mm2hReqs.map((r) => (
                <div class="flex items-center gap-2.5 text-slate-700 text-sm border-b border-dashed border-slate-200 pb-2.5"><span class="w-1.5 h-1.5 rounded-full bg-amber-400"></span>{r}</div>
              ))}
            </div>
            <p class="text-xs text-slate-400 mt-5 leading-relaxed">Exact thresholds depend on your selected MM2H category and are set by the Malaysian authorities.</p>
          </div>
        </div>
      </div>
    </section>

    {/* ============ PVIP ============ */}
    <section id="pvip" class="py-16 md:py-20 bg-gradient-to-b from-amber-50/40 to-white">
      <div class="max-w-6xl mx-auto px-6">
        <div class="grid lg:grid-cols-2 gap-12 items-start">
          <div class="lg:order-2">
            <span class="inline-block py-1 px-3 rounded-full bg-amber-100 text-amber-700 text-[11px] font-extrabold uppercase tracking-wider mb-4 border border-amber-200">Programme 2 · Premium</span>
            <h2 class="font-serif text-3xl md:text-4xl font-bold text-slate-900 mb-4">Malaysia Premium Visa <span class="text-amber-600">(PVIP)</span></h2>
            <p class="text-slate-600 leading-relaxed mb-6">A premium long-term stay programme for qualified foreigners, investors and families seeking the flexibility to live, work and invest in Malaysia — with no minimum stay requirement.</p>
            <h3 class="font-bold text-slate-900 mb-3">Key benefits</h3>
            <ul class="space-y-2.5 mb-6">
              {pvipBenefits.map((b) => (
                <li class="flex items-start gap-3 text-slate-700"><CheckCircle2 className="w-5 h-5 text-amber-600 flex-shrink-0 mt-0.5" /><span>{b}</span></li>
              ))}
            </ul>
            <a href={waPVIP} target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-amber-700 font-bold text-sm hover:gap-3 transition-all">Ask about PVIP <ArrowRight className="w-4 h-4" /></a>
          </div>
          <div class="lg:order-1 bg-white rounded-2xl border border-amber-100 p-7 shadow-sm">
            <h3 class="font-bold text-slate-900 mb-4 flex items-center gap-2"><FileText className="w-5 h-5 text-amber-600" /> Requirements</h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-3">
              {pvipReqs.map((r) => (
                <div class="flex items-center gap-2.5 text-slate-700 text-sm border-b border-dashed border-amber-100 pb-2.5"><span class="w-1.5 h-1.5 rounded-full bg-[#276CA1]"></span>{r}</div>
              ))}
            </div>
            <p class="text-xs text-slate-400 mt-5 leading-relaxed">Participation fee and deposit levels are set by the Malaysian authorities and may change.</p>
          </div>
        </div>
      </div>
    </section>

    {/* ============ COMPARE ============ */}
    <section id="compare" class="py-16 md:py-20 bg-white border-y border-slate-100">
      <div class="max-w-5xl mx-auto px-6">
        <div class="text-center max-w-2xl mx-auto mb-10">
          <h2 class="font-serif text-3xl md:text-4xl font-bold text-slate-900 mb-4">MM2H vs PVIP</h2>
          <p class="text-slate-600">A quick side-by-side to help you see which pathway fits your goals.</p>
        </div>
        <div class="overflow-hidden rounded-2xl border border-slate-200 shadow-sm">
          <table class="w-full text-left text-sm">
            <thead>
              <tr class="bg-slate-50 border-b border-slate-200">
                <th class="p-4 font-bold text-slate-500 uppercase tracking-wide text-xs"></th>
                <th class="p-4 font-bold text-[#276CA1]">MM2H</th>
                <th class="p-4 font-bold text-amber-600">PVIP</th>
              </tr>
            </thead>
            <tbody>
              {comparison.map((row, i) => (
                <tr class={i % 2 ? 'bg-slate-50/50' : 'bg-white'}>
                  <td class="p-4 font-semibold text-slate-700 align-top">{row.label}</td>
                  <td class="p-4 text-slate-600 align-top">{row.mm2h}</td>
                  <td class="p-4 text-slate-600 align-top">{row.pvip}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <p class="text-center text-slate-500 text-sm mt-6">Not sure which suits you? <a href={waGeneral} target="_blank" rel="noopener" class="text-[#276CA1] font-bold hover:underline">Get a free eligibility review →</a></p>
      </div>
    </section>

    {/* ============ APPLICATION PROCESS ============ */}
    <section class="py-16 md:py-20">
      <div class="max-w-5xl mx-auto px-6">
        <div class="text-center max-w-2xl mx-auto mb-12">
          <h2 class="font-serif text-3xl md:text-4xl font-bold text-slate-900 mb-4">The Application Process</h2>
          <p class="text-slate-600">A clear, guided path — from first consultation to visa endorsement.</p>
        </div>
        <div class="grid sm:grid-cols-2 gap-5">
          {steps.map((s) => (
            <div class="bg-white rounded-2xl border border-slate-100 p-6 shadow-sm">
              <div class="flex items-center gap-3 mb-3">
                <span class="font-serif text-2xl font-bold text-amber-500">{s.n}</span>
                <h3 class="font-bold text-slate-900">{s.title}</h3>
              </div>
              <p class="text-sm text-slate-600 leading-relaxed mb-2">{s.desc}</p>
              <p class="text-xs italic text-amber-700/80">{s.note}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ============ WHY DARO ============ */}
    <section class="py-16 md:py-20 bg-slate-900 text-white">
      <div class="max-w-6xl mx-auto px-6">
        <div class="text-center max-w-2xl mx-auto mb-12">
          <span class="inline-block py-1 px-3 rounded-full bg-white/10 text-amber-300 text-[11px] font-extrabold uppercase tracking-wider mb-4 border border-white/10">Our Licensed Partner</span>
          <h2 class="font-serif text-3xl md:text-4xl font-bold mb-4">Why Daro International?</h2>
          <p class="text-slate-300 leading-relaxed">A licensed Malaysia long-term stay advisory firm specialising in MM2H and PVIP applications, providing end-to-end support from consultation to final visa endorsement.</p>
        </div>
        <div class="grid grid-cols-3 gap-4 max-w-2xl mx-auto mb-14 text-center">
          <div><div class="font-serif text-3xl md:text-4xl font-bold text-amber-400">20+</div><div class="text-xs md:text-sm text-slate-400 mt-1">Years of experience</div></div>
          <div><div class="font-serif text-3xl md:text-4xl font-bold text-amber-400">1,000+</div><div class="text-xs md:text-sm text-slate-400 mt-1">Families served</div></div>
          <div><div class="font-serif text-3xl md:text-4xl font-bold text-amber-400">23+</div><div class="text-xs md:text-sm text-slate-400 mt-1">Countries represented</div></div>
        </div>
        <div class="grid sm:grid-cols-2 gap-5">
          {daroPillars.map((p) => (
            <div class="bg-white/5 rounded-2xl border border-white/10 p-6">
              <div class="w-11 h-11 rounded-xl bg-amber-400/15 text-amber-300 flex items-center justify-center mb-4"><p.icon className="w-5 h-5" /></div>
              <h3 class="font-bold text-white mb-3">{p.title}</h3>
              <ul class="space-y-1.5">
                {p.items.map((it) => (<li class="text-sm text-slate-300 flex items-center gap-2"><span class="w-1 h-1 rounded-full bg-amber-400"></span>{it}</li>))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ============ HOW OCHA + DARO WORK TOGETHER ============ */}
    <section class="py-16 md:py-20">
      <div class="max-w-6xl mx-auto px-6">
        <div class="text-center max-w-2xl mx-auto mb-12">
          <h2 class="font-serif text-3xl md:text-4xl font-bold text-slate-900 mb-4">How Ocha &amp; Daro Work Together</h2>
          <p class="text-slate-600 leading-relaxed">Together we provide a complete pathway — for clients coming to Malaysia for treatment, and those considering it as a longer-term home, recovery base, retirement destination or family hub.</p>
        </div>
        <div class="grid md:grid-cols-2 gap-6 mb-8">
          <div class="bg-blue-50/50 rounded-2xl border border-blue-100 p-7">
            <div class="w-11 h-11 rounded-xl bg-[#276CA1] text-white flex items-center justify-center mb-4"><HeartPulse className="w-5 h-5" /></div>
            <h3 class="font-bold text-slate-900 mb-2">Ocha — your healthcare journey</h3>
            <p class="text-sm text-slate-600 leading-relaxed">Specialist matching, medical appointment coordination, hospital arrangements and related patient support in Malaysia.</p>
          </div>
          <div class="bg-amber-50/60 rounded-2xl border border-amber-100 p-7">
            <div class="w-11 h-11 rounded-xl bg-amber-500 text-white flex items-center justify-center mb-4"><Landmark className="w-5 h-5" /></div>
            <h3 class="font-bold text-slate-900 mb-2">Daro — your long-term stay</h3>
            <p class="text-sm text-slate-600 leading-relaxed">Licensed MM2H and PVIP advisory, guiding eligible clients through eligibility, application and settlement.</p>
          </div>
        </div>
        <div class="bg-white rounded-2xl border border-slate-100 p-7 shadow-sm">
          <h3 class="font-bold text-slate-900 mb-4">Daro's support includes</h3>
          <div class="grid sm:grid-cols-2 gap-x-8 gap-y-2.5">
            {daroSupport.map((d) => (<div class="flex items-start gap-3 text-slate-700 text-sm"><CheckCircle2 className="w-4.5 h-4.5 text-amber-500 flex-shrink-0 mt-0.5" /><span>{d}</span></div>))}
          </div>
        </div>
      </div>
    </section>

    {/* ============ FAQ ============ */}
    <section class="py-16 md:py-20 bg-white border-t border-slate-100">
      <div class="max-w-3xl mx-auto px-6">
        <h2 class="font-serif text-3xl md:text-4xl font-bold text-slate-900 mb-10 text-center">Frequently Asked Questions</h2>
        <div class="space-y-3">
          {faqs.map((f) => (
            <details class="group bg-slate-50 rounded-xl border border-slate-100 p-5 open:bg-white open:shadow-sm transition-all">
              <summary class="flex items-center justify-between cursor-pointer font-bold text-slate-900 list-none">
                {f.q}
                <span class="text-[#276CA1] group-open:rotate-45 transition-transform text-xl leading-none">+</span>
              </summary>
              <p class="text-sm text-slate-600 leading-relaxed mt-3">{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    {/* ============ CTA ============ */}
    <section class="py-16 md:py-24 bg-gradient-to-br from-[#276CA1] to-[#1a476f] text-white">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <h2 class="font-serif text-3xl md:text-4xl font-bold mb-5">Plan your healthcare journey. Explore your long-term stay.</h2>
        <p class="text-blue-100 text-lg leading-relaxed mb-9">Exploring healthcare, retirement, family relocation or investment in Malaysia? Ocha can connect you with Daro International for a private MM2H or PVIP consultation.</p>
