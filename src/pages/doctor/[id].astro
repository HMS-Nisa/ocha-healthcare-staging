---
// src/pages/doctor/[id].astro
import LandingLayout from '../../layouts/LandingLayout.astro';
import { 
  Building2, Calendar, Globe, Stethoscope, 
  CheckCircle2, ChevronLeft, 
  Star, ArrowRight
} from 'lucide-react';
import { GOOGLE_SHEET_URL, WA_NUMBER } from '../../config';
import BookingWidget from '../../components/BookingWidget.jsx';
import { isDoctorIndexable, validatedDoctorRecords } from '../../lib/indexability.js';
import {
  absoluteUrl,
  buildDoctorPageTitle,
  normalizeDoctorSpecialtyLabel,
} from '../../lib/seo.js';

// 1. GENERATE STATIC PATHS & PASS RELATED DOCTORS
export async function getStaticPaths() {
  try {
    const noCacheUrl = `${GOOGLE_SHEET_URL}?t=${Date.now()}`;
    
    // 🚀 OMEGA CACHE-BUSTER: Forces the server to download fresh data
    const response = await fetch(noCacheUrl, {
        cache: 'no-store',
        headers: {
            'Cache-Control': 'no-cache, no-store, must-revalidate',
            'Pragma': 'no-cache',
            'Expires': '0'
        }
    });
    if (!response.ok) throw new Error(`HTTP ${response.status}`);
    
    const data = await response.json();
    
    const deduplicatedDoctors = validatedDoctorRecords(data);

    return deduplicatedDoctors.map(doc => {
      const related = deduplicatedDoctors
        .filter(d => d.id !== doc.id && (d.specialty === doc.specialty || d.location?.includes(doc.location?.split(',').pop())))
        .slice(0, 3);

      return {
        params: { id: doc.id }, 
        props: { doctor: doc, relatedDoctors: related }
      };
    });
  } catch (error) {
    throw new Error(`Doctor data fetch failed: ${error instanceof Error ? error.message : String(error)}`);
  }
}

const { doctor, relatedDoctors } = Astro.props;

// --- DATA PARSERS ---

// 🚀 BULLETPROOF BIO EXTRACTOR
let bioText = '';
for (const key in doctor) {
    const lowerKey = key.toLowerCase();
    if (lowerKey.includes('bio') || lowerKey.includes('profil')) {
        if (doctor[key] && String(doctor[key]).trim() !== '') {
            bioText = String(doctor[key]).trim();
            break; 
        }
    }
}

const languages = doctor.languages
  ? (Array.isArray(doctor.languages) ? doctor.languages : String(doctor.languages).split(','))
      .map(language => String(language).trim())
      .filter(Boolean)
  : [];

const locLower = doctor.location?.toLowerCase() || '';
const locationName = locLower.includes('penang') ? 'Penang' :
                     locLower.includes('kuala lumpur') || locLower.includes('kl') ? 'Kuala Lumpur' :
                     locLower.includes('selangor') ? 'Selangor' :
                     locLower.includes('melaka') ? 'Melaka' :
                     locLower.includes('johor') ? 'Johor' : 'Malaysia';

// 2. BULLETPROOF SCHEDULE PARSER
let parsedSchedule = [];
if (doctor.schedule) {
    let rawArray = [];
    
    if (Array.isArray(doctor.schedule)) {
        rawArray = doctor.schedule;
    } else if (typeof doctor.schedule === 'string') {
        const trimmedStr = doctor.schedule.trim();
        if (trimmedStr.startsWith('[')) {
            try { rawArray = JSON.parse(trimmedStr); } catch(e) { rawArray = [trimmedStr]; }
        } else {
            rawArray = trimmedStr.split(/[,;\n]/);
        }
    }

    const scheduleMap = {};
    
    rawArray.forEach(slot => {
        let day = '';
        let time = '-';
        
        if (typeof slot === 'object' && slot !== null) {
            day = slot.day || slot.Day || slot.hari || slot.Hari || Object.keys(slot)[0] || '';
            time = slot.time || slot.Time || slot.jam || slot.Jam || Object.values(slot)[0] || '-';
        } else {
            let text = String(slot).trim().replace(/^"|"$/g, '').trim();
            const match = text.match(/^([a-zA-Z\s]+)[\s:]+(.*)$/);
            if (match) {
                day = match[1].trim();
                time = match[2].trim();
            } else {
                day = text;
            }
        }
        
        day = String(day).trim();
        time = String(time).trim();

        if (day && day.length > 1 && day !== '[object Object]') {
            if (scheduleMap[day]) {
                if (!scheduleMap[day].includes(time)) {
                    scheduleMap[day].push(time);
                }
            } else {
                scheduleMap[day] = [time];
            }
        }
    });

    parsedSchedule = Object.keys(scheduleMap).map(day => ({
        day,
        times: scheduleMap[day]
    }));
}

const specialtyLabel = normalizeDoctorSpecialtyLabel(doctor.specialty);
const pageTitle = buildDoctorPageTitle(doctor);
const pageDescription = `Lihat profil ${doctor.name}, spesialis ${doctor.specialty} di ${doctor.hospital}, dan hubungi Ocha untuk koordinasi janji temu.`;
const indexable = isDoctorIndexable(doctor);
const doctorImage = doctor.image || '/assets/doctor-placeholder.png';
const canonical = absoluteUrl(`/doctor/${doctor.id}/`);
const webPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': `${canonical}#webpage`,
  url: canonical,
  name: pageTitle,
  description: pageDescription,
  inLanguage: 'id-ID',
  isPartOf: { '@id': 'https://ocha.health/#website' },
  ...(indexable ? { mainEntity: { '@id': `${canonical}#physician` } } : {}),
};
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  '@id': `${canonical}#breadcrumb`,
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Beranda', item: absoluteUrl('/') },
    { '@type': 'ListItem', position: 2, name: 'Cari Dokter', item: absoluteUrl('/doctors/') },
    { '@type': 'ListItem', position: 3, name: doctor.name, item: canonical },
  ],
};
const physicianSchema = indexable ? {
  '@context': 'https://schema.org',
  '@type': 'Physician',
  '@id': `${canonical}#physician`,
  name: doctor.name,
  url: absoluteUrl(`/doctor/${doctor.id}/`),
  image: String(doctorImage).startsWith('http') ? doctorImage : absoluteUrl(doctorImage),
  medicalSpecialty: doctor.specialty,
  hospitalAffiliation: { '@type': 'Hospital', name: doctor.hospital },
  address: doctor.location,
  ...(languages.length > 0 ? { availableLanguage: languages } : {}),
  ...(bioText ? { description: bioText } : {}),
} : null;
---

<LandingLayout
  title={pageTitle}
  description={pageDescription}
  robots={indexable ? 'index,follow' : 'noindex,follow'}
  canonicalPath={`/doctor/${doctor.id}/`}
  image={doctorImage}
  schemas={[webPageSchema, breadcrumbSchema, physicianSchema].filter(Boolean)}
>

{/* 🚀 FIX: Locked the background blob inside a hidden overflow container so it doesn't cause horizontal scrolling on mobile */}
  <div class="fixed top-0 left-0 w-full h-full overflow-hidden pointer-events-none -z-10">
      <div class="absolute top-0 right-0 w-[400px] h-[400px] md:w-[600px] md:h-[600px] bg-blue-50/50 rounded-full blur-3xl mix-blend-multiply opacity-50 translate-x-1/3 -translate-y-1/4"></div>
  </div>
  
  <div class="bg-transparent min-h-screen pb-28 lg:pb-20 pt-8 md:pt-16">
    
    <div class="max-w-4xl mx-auto px-4 sm:px-6 mb-8 relative z-10">
      <a href="/doctors" class="inline-flex items-center text-sm font-bold text-slate-500 hover:text-[#276CA1] transition-colors bg-white px-4 py-2 rounded-full shadow-sm border border-slate-200">
        <ChevronLeft className="w-4 h-4 mr-1" />
        Kembali ke Direktori
      </a>
    </div>

    <div class="max-w-4xl mx-auto px-4 sm:px-6 space-y-8 relative z-10">
        
        {/* HEADER & QUICK FACTS CARD */}
        <div class="bg-white rounded-3xl p-6 md:p-8 shadow-xl shadow-blue-900/5 border border-slate-100 flex flex-col sm:flex-row items-center sm:items-start gap-8">
          
          <div class="relative shrink-0">
             <div class="absolute inset-0 bg-blue-100 rounded-full blur-xl opacity-50 transform translate-y-2"></div>
             <img 
                src={doctorImage}
                alt={doctor.name}
                class="relative w-40 h-40 md:w-48 md:h-48 rounded-full object-cover object-top border-4 border-white shadow-lg bg-slate-50"
                onError={(e) => { e.currentTarget.src = '/assets/doctor-placeholder.png'; }}
             />
             <div class="absolute bottom-3 right-3 p-1.5 bg-green-500 border-4 border-white rounded-full text-white shadow-md" title="Spesialis Terverifikasi">
                <CheckCircle2 className="w-5 h-5" />
             </div>
          </div>
          
          <div class="flex-1 w-full text-center sm:text-left">
            <h1 class="font-serif text-3xl md:text-4xl font-bold text-slate-900 mb-3">{doctor.name}</h1>
            <div class="flex flex-wrap items-center justify-center sm:justify-start gap-2 mb-6">
                <span class="inline-block font-bold text-[#276CA1] uppercase tracking-widest text-xs bg-blue-50 px-3 py-1.5 rounded-lg border border-blue-100 shadow-sm">
                {doctor.specialty}
                </span>
                {doctor.subspecialty && (
                <span class="font-medium text-slate-600 text-xs flex items-center gap-1.5 bg-slate-100 px-3 py-1.5 rounded-lg border border-slate-200">
                    <span class="w-1.5 h-1.5 rounded-full bg-slate-400"></span>
                    {doctor.subspecialty}
                </span>
                )}
            </div>

            <div class="space-y-4 text-left border-t border-slate-100 pt-6">
                <div class="flex items-start gap-4">
                    <div class="p-2.5 bg-blue-50 text-[#276CA1] rounded-xl shrink-0">
                        <Building2 className="w-5 h-5" />
                    </div>
                    <div>
                        <p class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-0.5">Praktek Di</p>
                        <p class="font-bold text-slate-800 text-[15px]">{doctor.hospital}</p>
                    </div>
                </div>
                {languages.length > 0 && <div class="flex items-start gap-4">
                    <div class="p-2.5 bg-blue-50 text-[#276CA1] rounded-xl shrink-0">
                        <Globe className="w-5 h-5" />
                    </div>
                    <div>
                        <p class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-0.5">Bahasa</p>
                        <p class="font-medium text-slate-700 text-[15px]">{languages.join(', ')}</p>
                    </div>
                </div>}
            </div>
          </div>
        </div>

        {/* ABOUT / BIO SECTION */}
        <div class="bg-white rounded-3xl p-6 md:p-8 shadow-sm border border-slate-100">
           <div class="flex items-center gap-3 mb-6 border-b border-slate-100 pb-4">
             <div class="p-2.5 bg-indigo-50 text-indigo-600 rounded-xl">
               <Stethoscope className="w-5 h-5" />
             </div>
             <h2 class="font-serif text-2xl font-bold text-slate-900">Profil Medis</h2>
           </div>
           
           {bioText ? (
             <div class="prose prose-slate max-w-none text-slate-600 leading-relaxed whitespace-pre-line text-[15px] md:text-base">
               {bioText}
             </div>
           ) : (
             <p class="text-slate-500 italic">Informasi profil belum tersedia dari sumber rumah sakit mitra.</p>
           )}
        </div>

        {/* BOOKING WIDGET */}
        <div id="booking" class="bg-white rounded-3xl p-6 md:p-8 shadow-xl shadow-blue-900/5 border border-slate-100 scroll-mt-20">
          <div class="flex items-center gap-3 mb-6">
            <div class="p-2.5 bg-[#276CA1]/10 rounded-xl">
              <Calendar className="w-5 h-5 text-[#276CA1]" />
            </div>
            <h2 class="font-serif text-xl font-bold text-slate-900">Buat Janji Temu</h2>
          </div>
          <BookingWidget
            doctorName={doctor.name}
            hospital={doctor.hospital}
            waNumber={WA_NUMBER}
            specialty={doctor.specialty}
            location={locationName}
            client:load
          />
        </div>

        {/* TRUST SIGNALS: Testimonials */}
        <div class="bg-gradient-to-br from-blue-50 to-indigo-50/50 rounded-3xl p-6 md:p-8 border border-blue-100/50">
            <h2 class="font-serif text-2xl font-bold text-slate-900 mb-6">Pengalaman pasien yang dibantu Ocha</h2>
            <div class="grid sm:grid-cols-2 gap-4">
                <div class="bg-white p-5 rounded-2xl shadow-sm border border-slate-100/50 relative">
                    <div class="flex text-amber-400 mb-3 gap-0.5"><Star className="w-4 h-4 fill-current"/><Star className="w-4 h-4 fill-current"/><Star className="w-4 h-4 fill-current"/><Star className="w-4 h-4 fill-current"/><Star className="w-4 h-4 fill-current"/></div>
                    <p class="text-slate-600 text-sm mb-4 leading-relaxed">"Sangat bersyukur mendapat bantuan Ocha. Penjelasan prosesnya detail dan koordinasi janji temu sangat membantu."</p>
                    <p class="text-xs font-bold text-slate-900">Pasien via Ocha Healthcare</p>
                </div>
                <div class="bg-white p-5 rounded-2xl shadow-sm border border-slate-100/50 relative">
                    <div class="flex text-amber-400 mb-3 gap-0.5"><Star className="w-4 h-4 fill-current"/><Star className="w-4 h-4 fill-current"/><Star className="w-4 h-4 fill-current"/><Star className="w-4 h-4 fill-current"/><Star className="w-4 h-4 fill-current"/></div>
                    <p class="text-slate-600 text-sm mb-4 leading-relaxed">"Tim Ocha ramah dan sabar menjawab pertanyaan. Proses membuat janji dengan rumah sakit menjadi lebih jelas."</p>
                    <p class="text-xs font-bold text-slate-900">Pasien dari Indonesia</p>
                </div>
            </div>
        </div>

        {/* DYNAMIC FAQ FOR SEO */}
        <div class="bg-white rounded-3xl p-6 md:p-8 shadow-sm border border-slate-100">
           <h2 class="font-serif text-2xl font-bold text-slate-900 mb-6">FAQ tentang {doctor.name}</h2>
           <div class="space-y-4">
              <div class="border-b border-slate-100 pb-4">
                 <h3 class="font-bold text-slate-800 text-[15px]">Di rumah sakit mana {doctor.name} praktek?</h3>
                 <p class="text-slate-600 mt-2 text-sm leading-relaxed">Berdasarkan informasi rumah sakit mitra, {doctor.name} berpraktik di {doctor.hospital}{doctor.location ? `, ${doctor.location}` : ''}.</p>
              </div>
              <div class="border-b border-slate-100 pb-4">
                 <h3 class="font-bold text-slate-800 text-[15px]">Berapa biaya konsultasi & tindakan dengan {doctor.name}?</h3>
                 <p class="text-slate-600 mt-2 text-sm leading-relaxed">Biaya ditentukan oleh dokter dan rumah sakit setelah kebutuhan pasien dinilai. Ocha dapat membantu menghubungkan Anda untuk meminta janji temu dan informasi administratif.</p>
              </div>
              <div>
                 <h3 class="font-bold text-slate-800 text-[15px]">Bagaimana cara daftar berobat ke {doctor.name}?</h3>
                 <p class="text-slate-600 mt-2 text-sm leading-relaxed">Pilih jadwal pada formulir janji temu. Setelah itu, lanjutkan ke WhatsApp agar agen Ocha dapat mengoordinasikan permintaan Anda dengan rumah sakit mitra.</p>
              </div>
           </div>
        </div>

    </div>

    {/* === BOTTOM SECTION: RELATED DOCTORS === */}
    {relatedDoctors.length > 0 && (
    <div class="max-w-6xl mx-auto px-4 sm:px-6 mt-16 relative z-10">
        <h2 class="font-serif text-2xl font-bold text-slate-900 mb-8 border-b border-slate-200 pb-4">
            Rekomendasi Dokter Spesialis {specialtyLabel} di {locationName}
        </h2>
        <div class="grid md:grid-cols-3 gap-6">
            {relatedDoctors.map((relDoc) => (
                <a href={`/doctor/${relDoc.id}`} class="group bg-white rounded-2xl p-5 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all border border-slate-100 flex items-start gap-4">
                    <img 
                        src={relDoc.image || '/assets/doctor-placeholder.png'}
                        alt={relDoc.name}
                        class="w-16 h-16 rounded-full object-cover border-2 border-slate-50"
                        onError={(e) => { e.currentTarget.src = '/assets/doctor-placeholder.png'; }}
                    />
                    <div>
                        <h3 class="font-bold text-slate-900 group-hover:text-[#276CA1] transition-colors">{relDoc.name}</h3>
                        <p class="text-xs text-slate-500 mt-1 line-clamp-1">{relDoc.hospital}</p>
                        <div class="mt-2 inline-flex items-center text-xs font-bold text-[#276CA1]">
                            Lihat Profil <ArrowRight className="w-3 h-3 ml-1" />
                        </div>
                    </div>
                </a>
            ))}
        </div>
    </div>
    )}

  </div>

  {/* STICKY BOTTOM BAR */}
  <div class="fixed bottom-0 left-0 w-full bg-white border-t border-slate-200 px-4 py-3 z-50 shadow-[0_-10px_40px_rgba(0,0,0,0.1)]">
    <div class="max-w-4xl mx-auto">
      <a 
        href="#booking"
        class="w-full py-3 flex items-center justify-center gap-2 bg-[#276CA1] hover:bg-[#1e5a87] text-white font-bold rounded-xl transition-colors text-[15px]"
      >
        <Calendar className="w-5 h-5" />
        Buat Janji Temu
      </a>
    </div>
  </div>

</LandingLayout>
