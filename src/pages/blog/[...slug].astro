---
// src/pages/blog/[...slug].astro
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { 
  Calendar, Clock,
  User, Search, ArrowRight
} from 'lucide-react';
import { absoluteUrl } from '../../lib/seo.js';

// 1. GENERATE PATHS
export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

// 2. GET DATA
const { entry } = Astro.props;
const { Content } = await entry.render();
const canonicalPath = `/blog/${entry.slug}/`;
const canonical = absoluteUrl(canonicalPath);
const socialImage = new URL(entry.data.image, 'https://ocha.health/').href;

const formatDate = (date) => date.toLocaleDateString('id-ID', {
  year: 'numeric', month: 'long', day: 'numeric'
});
const breadcrumbs = [
  { name: 'Beranda', href: '/' },
  { name: 'Panduan', href: '/blog/' },
  { name: entry.data.title },
];
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  '@id': `${canonical}#article`,
  headline: entry.data.title,
  description: entry.data.subtitle,
  image: socialImage,
  datePublished: entry.data.date.toISOString(),
  dateModified: entry.data.updatedDate.toISOString(),
  mainEntityOfPage: canonical,
  author: { '@type': 'Organization', '@id': 'https://ocha.health/#organization', name: 'Ocha Healthcare' },
  publisher: { '@type': 'Organization', '@id': 'https://ocha.health/#organization', name: 'Ocha Healthcare' },
  ...(entry.data.reviewer ? { reviewedBy: { '@type': 'Person', name: entry.data.reviewer } } : {}),
};
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  '@id': `${canonical}#breadcrumb`,
  itemListElement: breadcrumbs.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: item.name,
    item: item.href ? absoluteUrl(item.href) : canonical,
  })),
};
const faqPageSchema = entry.data.faq ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': `${canonical}#faq`,
  mainEntity: entry.data.faq.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: { '@type': 'Answer', text: item.answer },
  })),
} : null;
---

<Layout
  title={entry.data.title}
  description={entry.data.subtitle}
  canonicalPath={canonicalPath}
  robots={entry.data.robots}
  image={socialImage}
  contentType="article"
  schemas={[articleSchema, breadcrumbSchema, faqPageSchema].filter(Boolean)}
>
  
  {/* Progress Bar */}
  <div id="progress-container" class="fixed top-0 left-0 w-full h-1 bg-slate-200 z-50">
    <div id="progress-bar" class="h-full bg-[#276CA1] w-0 transition-all duration-150"></div>
  </div>

  {/* 🚀 PADDING UPDATE: Reduced to pt-20 lg:pt-24 to match other pages */}
  <div class="bg-white min-h-screen pb-32 pt-20 lg:pt-24">
    
    {/* BREADCRUMB */}
    <div class="max-w-7xl mx-auto px-4 sm:px-6 mb-8">
      <Breadcrumbs items={breadcrumbs} />
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 grid lg:grid-cols-12 gap-12">
      
      {/* MAIN ARTICLE (8 Cols) */}
      <div class="lg:col-span-8">
        
        <span class="inline-block py-1 px-3 rounded-full bg-blue-50 text-[#276CA1] text-xs font-bold uppercase tracking-wider mb-6">
          {entry.data.category}
        </span>

        <h1 class="font-serif text-3xl md:text-5xl font-bold text-slate-900 mb-6 leading-tight">
          {entry.data.title}
        </h1>
        <p class="text-xl text-slate-500 leading-relaxed mb-8">
          {entry.data.subtitle}
        </p>

        {/* Metadata */}
        <div class="flex flex-wrap items-center gap-6 text-sm text-slate-500 border-b border-slate-100 pb-8 mb-10">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full bg-indigo-50 flex items-center justify-center text-indigo-600">
                    <User className="w-5 h-5" />
                </div>
                <div>
                    <p class="text-slate-900 font-bold">{entry.data.author}</p>
                    <p class="text-xs">Tim editorial Ocha Healthcare</p>
                </div>
            </div>
            <div class="hidden sm:block w-px h-8 bg-slate-200"></div>
            <div class="w-full sm:w-auto mt-4 sm:mt-0 flex flex-wrap items-center gap-4 text-xs text-slate-500 font-medium">
                <span class="flex items-center gap-1"><Calendar className="w-3.5 h-3.5" /> Terbit {formatDate(entry.data.date)}</span>
                <span>Diperbarui {formatDate(entry.data.updatedDate)}</span>
                <span class="flex items-center gap-1"><Clock className="w-3.5 h-3.5" /> {entry.data.readTime}</span>
            </div>
            {entry.data.reviewer && <p class="w-full text-xs text-slate-500">Ditinjau oleh {entry.data.reviewer}</p>}
        </div>

        {/* Featured Image */}
        <div class="relative rounded-3xl overflow-hidden shadow-lg shadow-slate-200/50 mb-12">
            <img src={entry.data.image} alt={entry.data.title} class="w-full h-[400px] object-cover" />
        </div>

        {/* CONTENT RENDERER */}
        <article class="ocha-article prose prose-lg prose-slate max-w-none">
            <Content />
        </article>

        {entry.data.faq && (
          <section class="mt-12" aria-labelledby="article-faq">
            <h2 id="article-faq" class="font-serif text-2xl font-bold text-slate-900">Pertanyaan yang sering diajukan</h2>
            <div class="mt-6 space-y-6">
              {entry.data.faq.map((item) => (
                <div>
                  <h3 class="font-serif text-lg font-bold text-slate-900">{item.question}</h3>
                  <p class="mt-2 leading-7 text-slate-600">{item.answer}</p>
                </div>
              ))}
            </div>
          </section>
        )}

        <section class="mt-12 rounded-2xl border border-slate-200 bg-slate-50 p-6" aria-label="Sumber dan disclaimer medis">
          {entry.data.sources && (
            <>
              <h2 id="article-sources" class="font-serif text-xl font-bold text-slate-900">Sumber</h2>
              <ul class="mt-4 space-y-2 text-sm">
                {entry.data.sources.map((source) => (
                  <li><a class="font-semibold text-[#276CA1] hover:underline" href={source.url} target="_blank" rel="noreferrer">{source.label}</a></li>
                ))}
              </ul>
            </>
          )}
          <p class="mt-6 border-l-4 border-amber-400 pl-4 text-sm leading-6 text-slate-600"><strong>Disclaimer medis:</strong> {entry.data.medicalDisclaimer}</p>
        </section>

        {/* Directory CTA */}
        <div class="border-t border-slate-100 mt-16 pt-10">
            <div class="bg-indigo-50 rounded-2xl p-8 flex flex-col sm:flex-row items-center justify-between gap-6 text-center sm:text-left border border-indigo-100">
                <div>
                    <h3 class="font-serif text-xl font-bold text-slate-900 mb-2">Siap memilih jadwal?</h3>
                    <p class="text-slate-600">Pilih spesialis lalu ajukan tanggal dan waktu pilihan. Setelah itu, lanjutkan koordinasi melalui WhatsApp dengan agen Ocha.</p>
                </div>
                <a href="/doctors/" class="shrink-0 bg-indigo-600 text-white px-8 py-4 rounded-full font-bold text-sm hover:bg-indigo-700 transition shadow-lg shadow-indigo-200 flex items-center gap-2 group hover:-translate-y-0.5">
                    <Search className="w-4 h-4" />
                    Pilih Jadwal
                    <ArrowRight className="w-4 h-4 opacity-50 group-hover:translate-x-1 transition-transform" />
                </a>
            </div>
        </div>

      </div>

      {/* SIDEBAR */}
      <div class="lg:col-span-4 space-y-8">
        <div class="sticky top-32">
            <div class="bg-white rounded-2xl shadow-xl shadow-blue-900/5 border border-slate-100 p-6 overflow-hidden relative group">
                <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-to-br from-blue-50 to-indigo-50 rounded-bl-[100px] -z-10 transition group-hover:scale-110"></div>
                <div class="mb-6">
                    <span class="inline-block py-1 px-3 rounded-full bg-emerald-100 text-emerald-800 text-[10px] font-bold uppercase tracking-wider mb-4">Koordinasi Gratis</span>
                    <h3 class="font-serif text-xl font-bold text-slate-900 mb-2">Mulai dengan memilih jadwal</h3>
                    <p class="text-sm text-slate-500 leading-relaxed">Pilih spesialis lalu ajukan tanggal dan waktu pilihan, kemudian lanjutkan melalui WhatsApp. Agen Ocha meninjau kebutuhan Anda secara manual.</p>
                </div>
                <a href="/doctors/" class="block w-full py-4 bg-[#276CA1] hover:bg-[#1f5682] text-white text-center font-bold rounded-xl shadow-lg hover:shadow-xl hover:-translate-y-1 transition-all flex items-center justify-center gap-2">
                    <Search className="w-4 h-4" />
                    Pilih Jadwal
                </a>
            </div>
        </div>
      </div>

    </div>
  </div>

  <script>
    window.addEventListener('scroll', () => {
      const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
      const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
      const scrolled = (winScroll / height) * 100;
      const progressBar = document.getElementById("progress-bar");
      if(progressBar) progressBar.style.width = scrolled + "%";
    });
  </script>
</Layout>

<style is:global>
  /* FORCE STYLING FOR MARKDOWN CONTENT */
  
  .ocha-article h2 {
    font-family: 'Lora', serif;
    font-size: 1.875rem;
    font-weight: 700;
    color: #0f172a;
    margin-top: 3rem;
    margin-bottom: 1.5rem;
  }

  .ocha-article h3 {
    font-family: 'Lora', serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: #1e293b;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .ocha-article p {
    margin-bottom: 1.5rem;
    line-height: 1.8;
    color: #475569;
  }

  .ocha-article ul {
    list-style-type: disc;
    padding-left: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .ocha-article ol {
    list-style-type: decimal;
    padding-left: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .ocha-article li {
    margin-bottom: 0.5rem;
    color: #475569;
  }

  .ocha-article strong {
    color: #0f172a;
    font-weight: 700;
  }

  .ocha-article blockquote {
    border-left: 4px solid #276CA1;
    background-color: #eff6ff;
    padding: 1.5rem;
    border-radius: 0 0.5rem 0.5rem 0;
    font-style: italic;
    color: #1e40af;
    margin: 2rem 0;
  }

  .ocha-article table {
    width: 100%;
    margin: 2rem 0;
    border-collapse: collapse;
    font-size: 0.875rem;
    border: 1px solid #e2e8f0;
    border-radius: 0.5rem;
    overflow: hidden;
  }

  .ocha-article th {
    background-color: #f8fafc;
    text-align: left;
    padding: 0.75rem 1rem;
    font-weight: 700;
    color: #334155;
    border-bottom: 2px solid #e2e8f0;
  }

  .ocha-article td {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid #e2e8f0;
    color: #475569;
  }
  
  .ocha-article tr:last-child td {
    border-bottom: none;
  }
</style>
