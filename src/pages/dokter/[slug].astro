---
import LandingLayout from '../../layouts/LandingLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { Building2, Calendar, CheckCircle2, MapPin, MessageCircle } from 'lucide-react';
import { getPublishedDoctors } from '../../lib/doctors.js';
import { isDoctorIndexable, validatedDoctorRecords } from '../../lib/indexability.js';
import {
  isSpecialtyLocationIndexable,
  slugifySegment,
  specialtyLocationSlug,
} from '../../lib/slugs.js';
import { absoluteUrl } from '../../lib/seo.js';

export async function getStaticPaths() {
  const specialtyTranslations = {
    Cardiology: 'jantung',
    'Cardiothoracic Surgery': 'bedah-thoraks-kardio',
    Orthopaedics: 'tulang-orthopedi',
    Paediatrics: 'anak',
    'Obstetrics & Gynaecology': 'kandungan-obgyn',
    Oncology: 'kanker-onkologi',
    Neurology: 'saraf',
    Neurosurgery: 'bedah-saraf',
    Urology: 'urologi-ginjal',
    Gastroenterology: 'pencernaan-gastro',
    ENT: 'tht',
    Ophthalmology: 'mata',
    'General Surgery': 'bedah-umum',
    'Internal Medicine': 'penyakit-dalam',
    Fertility: 'bayi-tabung-ivf',
  };

  const locationName = (location = '') => {
    const address = String(location).toLowerCase();
    if (address.includes('penang') || address.includes('pulau pinang')) return 'Penang';
    if (address.includes('kuala lumpur') || /\bkl\b/.test(address) || address.includes('bukit jalil')) return 'Kuala Lumpur';
    if (address.includes('selangor') || address.includes('subang') || address.includes('petaling') || address.includes('sunway')) return 'Selangor';
    if (address.includes('melaka') || address.includes('malacca')) return 'Melaka';
    if (address.includes('johor') || /\bjb\b/.test(address)) return 'Johor';
    if (address.includes('kuantan') || address.includes('pahang')) return 'Kuantan';
    if (address.includes('ipoh') || address.includes('perak')) return 'Ipoh';
    if (address.includes('kuching') || address.includes('sarawak')) return 'Sarawak';
    if (address.includes('kota kinabalu') || address.includes('sabah')) return 'Sabah';
    if (address.includes('negeri sembilan') || address.includes('seremban')) return 'Seremban';
    return 'Malaysia';
  };

  const doctors = validatedDoctorRecords(await getPublishedDoctors(), ['id', 'name', 'specialty', 'location'])
    .map((doctor) => ({
      ...doctor,
      city: locationName(doctor.location),
      indexable: isDoctorIndexable(doctor),
    }));

  const combinations = new Map();
  for (const doctor of doctors) {
    const sourceSpecialty = String(doctor.specialty).trim();
    const specialty = sourceSpecialty.replace(/^dokter\s+spesialis\s+/i, '').trim();
    const specialtySegment = specialtyTranslations[sourceSpecialty]
      || specialtyTranslations[specialty]
      || slugifySegment(specialty);
    const slug = specialtyLocationSlug(`dokter-spesialis-${specialtySegment}`, doctor.city);

    if (!combinations.has(slug)) {
      combinations.set(slug, { slug, specialty, city: doctor.city, doctors: [] });
    }
    combinations.get(slug).doctors.push(doctor);
  }

  return Array.from(combinations.values()).map((combination) => ({
    params: { slug: combination.slug },
    props: combination,
  }));
}

const { slug, doctors, specialty, city } = Astro.props;
const doctorCount = doctors.length;
const indexableDoctors = doctors.filter((doctor) => doctor.indexable === true);
const indexable = isSpecialtyLocationIndexable(doctors);
const hospitals = [...new Set(doctors.map((doctor) => String(doctor.hospital || '').trim()).filter(Boolean))];
const canonicalPath = `/dokter/${slug}/`;
const pageTitle = `Dokter Spesialis ${specialty} di ${city}`;
const pageDescription = `Temukan ${doctorCount} profil dokter spesialis ${specialty} di ${city} dalam jaringan mitra Ocha dan minta bantuan untuk koordinasi janji temu.`;
const canonical = absoluteUrl(canonicalPath);

const webPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': `${canonical}#webpage`,
  url: canonical,
  name: pageTitle,
  description: pageDescription,
  inLanguage: 'id-ID',
  isPartOf: { '@id': 'https://ocha.health/#website' },
  ...(indexable ? { mainEntity: { '@id': `${canonical}#doctor-list` } } : {}),
};

const breadcrumbItems = [
  { name: 'Beranda', href: '/' },
  { name: 'Cari Dokter', href: '/doctors/' },
  { name: `${specialty} di ${city}`, href: canonicalPath },
];

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  '@id': `${canonical}#breadcrumb`,
  itemListElement: breadcrumbItems.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: item.name,
    item: absoluteUrl(item.href),
  })),
};

const itemListSchema = indexable ? {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  '@id': `${canonical}#doctor-list`,
  name: `Dokter spesialis ${specialty} di ${city}`,
  numberOfItems: indexableDoctors.length,
  itemListElement: indexableDoctors.map((doctor, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    url: absoluteUrl(`/doctor/${doctor.id}/`),
    name: doctor.name,
  })),
} : null;

const faqItems = [
  {
    question: `Bagaimana cara meminta janji dengan dokter ${specialty} di ${city}?`,
    answer: 'Pilih profil dokter, ajukan tanggal dan waktu pilihan, lalu kirim permintaan melalui WhatsApp. Agen Ocha akan meninjau permintaan dan membantu koordinasi dengan rumah sakit mitra.',
  },
  {
    question: `Apakah Ocha menentukan dokter ${specialty} yang paling tepat?`,
    answer: `Ocha membantu mencocokkan kebutuhan pasien dengan pilihan dalam jaringan mitra di ${city}. Rekomendasi ditinjau manusia dan bukan diagnosis atau keputusan medis.`,
  },
  {
    question: `Apakah layanan koordinasi Ocha untuk rumah sakit di ${city} berbayar?`,
    answer: 'Layanan Ocha gratis untuk pasien. Ocha memperoleh pendapatan melalui kemitraan rumah sakit yang diungkapkan kepada pasien.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: { '@type': 'Answer', text: item.answer },
  })),
};
---

<LandingLayout
  title={pageTitle}
  description={pageDescription}
  canonicalPath={canonicalPath}
  robots={indexable ? 'index,follow' : 'noindex,follow'}
  schemas={[webPageSchema, breadcrumbSchema, itemListSchema, faqSchema].filter(Boolean)}
>
  <section class="border-b border-slate-200 bg-slate-50 py-10 md:py-16">
    <div class="mx-auto max-w-6xl px-4 md:px-6">
      <Breadcrumbs items={breadcrumbItems} />
      <div class="mt-8 max-w-3xl">
        <span class="mb-2 block text-xs font-bold uppercase tracking-wider text-[#276CA1]">Jaringan rumah sakit mitra</span>
        <h1 class="font-serif text-3xl font-bold leading-tight text-slate-900 md:text-5xl">
          Dokter Spesialis <span class="text-[#276CA1]">{specialty}</span> di {city}
        </h1>
        <p class="mt-4 text-lg leading-relaxed text-slate-600">
          Bandingkan {doctorCount} profil yang tersedia. Ocha membantu pasien Indonesia meminta janji dan terhubung dengan agen untuk koordinasi bersama rumah sakit mitra.
        </p>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-16">
    <div class="mx-auto max-w-6xl px-4 md:px-6">
      <h2 class="mb-6 font-serif text-2xl font-bold text-slate-900">Pilihan dokter yang tersedia</h2>
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {doctors.map((doctor) => (
          <article class="flex h-full flex-col rounded-[20px] border border-slate-100 bg-white p-6 shadow-sm">
            <div class="mb-5 flex items-start gap-4">
              <img
                src={doctor.image || '/assets/doctor-placeholder.png'}
                alt={doctor.name}
                class="h-16 w-16 shrink-0 rounded-full border-2 border-slate-50 bg-slate-100 object-cover object-top"
              />
              <div class="min-w-0">
                <h3 class="font-serif text-lg font-bold leading-tight text-slate-900">{doctor.name}</h3>
                <p class="mt-1 text-xs font-bold uppercase tracking-wide text-[#276CA1]">{doctor.specialty}</p>
                {doctor.subspecialty && <p class="mt-1 text-xs text-slate-500">{doctor.subspecialty}</p>}
              </div>
            </div>
            <div class="mb-6 space-y-2 border-t border-slate-100 pt-4 text-sm">
              <p class="flex items-start gap-2 text-slate-600"><Building2 className="mt-0.5 h-4 w-4 shrink-0 text-slate-400" /> {doctor.hospital}</p>
              <p class="flex items-start gap-2 text-slate-500"><MapPin className="mt-0.5 h-4 w-4 shrink-0 text-slate-400" /> {doctor.location}</p>
            </div>
            <a href={`/doctor/${doctor.id}/#booking`} class="mt-auto rounded-xl bg-[#276CA1] px-4 py-3 text-center text-sm font-bold text-white transition-colors hover:bg-[#1f5682]">
              Lihat Profil & Pilih Jadwal
            </a>
          </article>
        ))}
      </div>

      <div class="mt-12 rounded-3xl border border-blue-100 bg-blue-50 p-6 md:p-8">
        <h2 class="font-serif text-2xl font-bold text-slate-900">Rumah sakit yang terwakili di {city}</h2>
        <ul class="mt-4 grid gap-3 sm:grid-cols-2">
          {hospitals.map((hospital) => (
            <li class="flex items-center gap-2 text-slate-700"><CheckCircle2 className="h-4 w-4 shrink-0 text-[#276CA1]" /> {hospital}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="bg-slate-900 py-12 text-white md:py-16">
    <div class="mx-auto max-w-6xl px-4 md:px-6">
      <h2 class="font-serif text-3xl font-bold">Cara meminta janji melalui Ocha</h2>
      <ol class="mt-8 grid gap-4 md:grid-cols-4">
        <li class="rounded-2xl bg-white/10 p-5"><span class="font-bold text-blue-200">1.</span><h3 class="mt-2 font-bold">Pilih profil</h3><p class="mt-2 text-sm text-slate-300">Bandingkan informasi dokter dan rumah sakit yang tersedia.</p></li>
        <li class="rounded-2xl bg-white/10 p-5"><span class="font-bold text-blue-200">2.</span><h3 class="mt-2 flex items-center gap-2 font-bold"><Calendar className="h-4 w-4" /> Pilih jadwal</h3><p class="mt-2 text-sm text-slate-300">Ajukan tanggal dan waktu pilihan melalui kalender pada profil dokter.</p></li>
        <li class="rounded-2xl bg-white/10 p-5"><span class="font-bold text-blue-200">3.</span><h3 class="mt-2 flex items-center gap-2 font-bold"><MessageCircle className="h-4 w-4" /> Kirim WhatsApp</h3><p class="mt-2 text-sm text-slate-300">Lengkapi permintaan dengan menghubungi agen Ocha.</p></li>
        <li class="rounded-2xl bg-white/10 p-5"><span class="font-bold text-blue-200">4.</span><h3 class="mt-2 font-bold">Ditinjau agen</h3><p class="mt-2 text-sm text-slate-300">Agen meninjau dan membantu koordinasi dengan rumah sakit mitra.</p></li>
      </ol>
    </div>
  </section>

  <section class="py-12 md:py-16">
    <div class="mx-auto max-w-4xl px-4 md:px-6">
      <h2 class="font-serif text-3xl font-bold text-slate-900">Pertanyaan tentang dokter {specialty} di {city}</h2>
      <div class="mt-8 space-y-4">
        {faqItems.map((item) => (
          <article class="rounded-2xl border border-slate-200 bg-white p-6">
            <h3 class="font-bold text-slate-900">{item.question}</h3>
            <p class="mt-3 leading-relaxed text-slate-600">{item.answer}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</LandingLayout>
