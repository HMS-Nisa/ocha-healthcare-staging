---
// src/pages/index.astro
// 🚀 CHANGE: Import LandingLayout (which has the Footer, Navbar & Tracking)
import LandingLayout from '../layouts/LandingLayout.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import Testimonials from '../components/Testimonials.astro';
import FAQ from '../components/FAQ.astro';
import CTA from '../components/CTA.astro';

// We use the new React component for Hubs
import MedicalHubs from '../components/MedicalHubs.jsx';
import { buildOrganizationSchema } from '../lib/seo.js';

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': 'https://ocha.health/#website',
  url: 'https://ocha.health/',
  name: 'Ocha Healthcare',
  description: 'Concierge medis untuk pasien Indonesia yang mencari dokter spesialis dan rumah sakit mitra di Malaysia.',
  inLanguage: 'id-ID',
};
---

{/* 🚀 CHANGE: Use <LandingLayout> instead of <Layout> */}
<LandingLayout 
  title="Temukan Dokter Spesialis di Malaysia"
  description="Ocha membantu pasien Indonesia terhubung dengan dokter spesialis dan rumah sakit mitra di Malaysia secara gratis dan mudah."
  canonicalPath="/"
  schemas={[buildOrganizationSchema(), websiteSchema]}
>
  <main>
    <Hero />
    
    <MedicalHubs client:visible />
    
    <Features />
    
    <Testimonials />
    
    <FAQ />
    
    <CTA />
  </main>
</LandingLayout>
