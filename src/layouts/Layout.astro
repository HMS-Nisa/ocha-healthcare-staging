---
// src/layouts/Layout.astro
import { Menu, X, Search } from 'lucide-react';

// Props: Title is required, Description is optional
const { title, description } = Astro.props;

// 🚀 UPDATED: New Concierge Link
const WA_LINK = "https://api.whatsapp.com/send/?phone=60125525544&text&type=phone_number&app_absent=0";
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description || "Ocha Healthcare - AI-Powered Medical Concierge. Expert care in Malaysia, sorted in seconds."} />
		<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
		
		<link rel="icon" type="image/png" href="/favicon.png" />
		<meta name="google-site-verification" content="google-site-verification=J_CcoFq3Zit_9hKWH3wSgKkM1uW7tV7IqC5WpX8X9c8" />
		<meta name="generator" content={Astro.generator} />
		
		{/* Google Fonts */}
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
		
		<title>{title}</title>

        {/* 📊 GOOGLE TAG MANAGER (GTM) */}
        <script is:inline>
            (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
            new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
            j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
            'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
            })(window,document,'script','dataLayer','GTM-P59DXCBC');
        </script>
	</head>
	
	<body class="bg-slate-50 font-sans text-slate-900 antialiased selection:bg-indigo-100 selection:text-indigo-900 flex flex-col min-h-screen overflow-x-hidden">
		
        {/* 📊 GOOGLE TAG MANAGER (noscript) */}
        <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-P59DXCBC" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>

		{/* === NAVBAR (Glassmorphism) === */}
		<nav class="fixed w-full z-50 bg-white/95 backdrop-blur-md border-b border-slate-200 transition-all duration-300 shadow-sm">
			<div class="max-w-7xl mx-auto px-6 h-20 flex justify-between items-center relative">
				
				{/* 1. LOGO & LINKS (Left) */}
				<div class="flex items-center gap-8">
					<a href="/" class="flex-shrink-0 opacity-100 hover:opacity-80 active:scale-95 transition-all z-50">
						<img src="/assets/logo.png" alt="Ocha Healthcare" class="h-12 w-auto object-contain mix-blend-multiply" />
					</a>

                    {/* Desktop Navigation */}
                    <div class="hidden md:flex items-center gap-6">
						<a href="/" class="text-sm font-bold text-slate-500 hover:text-[#276CA1] transition-colors">Home</a>
						<a href="/doctors" class="text-sm font-bold text-slate-500 hover:text-[#276CA1] transition-colors">Doctors</a>
						<a href="/blog" class="text-sm font-bold text-slate-500 hover:text-[#276CA1] transition-colors flex items-center gap-1">
							Guides <span class="bg-blue-50 text-[#276CA1] text-[10px] px-1.5 py-0.5 rounded-full border border-blue-100">New</span>
						</a>
					</div>
				</div>

				{/* 2. ACTION BUTTONS (Right - Desktop Only) */}
				<div class="hidden md:flex items-center gap-3">
					<a href="/doctors" class="flex items-center gap-2 px-5 py-2.5 rounded-full text-sm font-bold text-slate-700 bg-white border border-slate-200 hover:bg-slate-50 hover:border-blue-200 transition-all group">
						<Search className="w-4 h-4 text-slate-400 group-hover:text-[#276CA1] transition-colors" />
						Find Specialist
					</a>
					<a href={WA_LINK} target="_blank" class="bg-[#276CA1] text-white px-6 py-2.5 rounded-full text-sm font-bold hover:bg-[#1f5682] transition shadow-lg shadow-blue-900/20 active:scale-95 transform duration-150 flex items-center gap-2">
						Book Consultation
					</a>
				</div>

				{/* 3. MOBILE MENU TOGGLE BUTTON */}
				<button id="menu-btn" class="md:hidden text-slate-600 p-2 z-50 focus:outline-none hover:bg-slate-100 active:scale-90 active:bg-slate-200 rounded-full transition-all duration-200">
					<div class="icon-menu block">
						<Menu className="w-6 h-6" />
					</div>
					<div class="icon-close hidden">
						<X className="w-6 h-6" />
					</div>
				</button>
			</div>
		</nav>

		{/* 🚀 NEW: MOBILE MENU OVERLAY (Darkened Backdrop) */}
		<div id="mobile-overlay" class="fixed inset-0 z-40 bg-slate-900/40 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300 md:hidden"></div>

		{/* 🚀 UPDATED: MOBILE MENU DRAWER (Slides from right, sleek touch feedback) */}
		<div id="mobile-menu" class="fixed top-0 right-0 h-full w-[85%] max-w-[320px] z-40 bg-white transform translate-x-full transition-transform duration-300 ease-[cubic-bezier(0.4,0,0.2,1)] md:hidden flex flex-col pt-24 px-4 gap-2 shadow-2xl overflow-y-auto pb-8">
			
            {/* Nav Links with active touch states */}
			<a href="/" class="text-lg font-bold text-slate-700 p-4 rounded-xl hover:bg-slate-50 active:bg-slate-100 active:scale-[0.98] transition-all">
				Concierge Home
			</a>
			
			<a href="/blog" class="text-lg font-bold text-slate-700 p-4 rounded-xl hover:bg-slate-50 active:bg-slate-100 active:scale-[0.98] transition-all flex items-center justify-between">
				Health Guides 
				<span class="bg-blue-50 text-[#276CA1] text-xs font-bold px-2 py-1 rounded-full border border-blue-100">New</span>
			</a>

			<a href="/doctors" class="text-lg font-bold text-slate-700 p-4 rounded-xl hover:bg-slate-50 active:bg-slate-100 active:scale-[0.98] transition-all flex items-center justify-between">
				Find Specialist <Search className="w-5 h-5 text-slate-400" />
			</a>
			
			<div class="mt-4 px-2">
				<a href={WA_LINK} target="_blank" class="block w-full bg-[#276CA1] text-white text-center py-4 rounded-xl font-bold text-[15px] shadow-lg shadow-blue-900/20 active:scale-95 active:bg-[#1f5682] transition-all duration-200">
					Book Consultation
				</a>
			</div>
		</div>

		{/* === MAIN CONTENT === */}
		<div class="flex-grow pt-20">
			<slot />
		</div>

		{/* === FOOTER === */}
		<footer class="bg-white border-t border-slate-200 py-12 mt-auto">
			<div class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row justify-between items-center gap-6">
				<div class="opacity-80 grayscale hover:grayscale-0 transition-all duration-500">
					<img src="/assets/logo.jpg" alt="Ocha Healthcare" class="h-10 w-auto object-contain mix-blend-multiply" />
				</div>
				<div class="text-slate-400 text-sm text-center md:text-right font-medium">
					© {new Date().getFullYear()} Ocha Healthcare. All rights reserved.
				</div>
			</div>
		</footer>

		{/* === MOBILE MENU SCRIPT (With Outside Tap Detection) === */}
		<script is:inline>
			const menuBtn = document.getElementById('menu-btn');
			const mobileMenu = document.getElementById('mobile-menu');
			const overlay = document.getElementById('mobile-overlay');
			const iconMenu = document.querySelector('.icon-menu');
			const iconClose = document.querySelector('.icon-close');
			let isMenuOpen = false;

			const toggleMenu = () => {
				isMenuOpen = !isMenuOpen;
				if (isMenuOpen) {
					// Open Menu
					mobileMenu.classList.remove('translate-x-full');
					mobileMenu.classList.add('translate-x-0');
					
					// Show Overlay
					overlay.classList.remove('opacity-0', 'pointer-events-none');
					overlay.classList.add('opacity-100', 'pointer-events-auto');
					
					document.body.classList.add('overflow-hidden');
					
					// Swap Icons
					iconMenu.classList.remove('block');
					iconMenu.classList.add('hidden');
					iconClose.classList.remove('hidden');
					iconClose.classList.add('block');
				} else {
					// Close Menu
					mobileMenu.classList.remove('translate-x-0');
					mobileMenu.classList.add('translate-x-full');
					
					// Hide Overlay
					overlay.classList.remove('opacity-100', 'pointer-events-auto');
					overlay.classList.add('opacity-0', 'pointer-events-none');
					
					document.body.classList.remove('overflow-hidden');
					
					// Swap Icons
					iconMenu.classList.remove('hidden');
					iconMenu.classList.add('block');
					iconClose.classList.remove('block');
					iconClose.classList.add('hidden');
				}
			};

			if (menuBtn && mobileMenu && overlay && iconMenu && iconClose) {
				// Toggle via button
				menuBtn.addEventListener('click', toggleMenu);
				
				// 🚀 Auto-close when tapping outside (the overlay)
				overlay.addEventListener('click', () => {
					if (isMenuOpen) toggleMenu();
				});

				// Close menu when a link is clicked
				const links = mobileMenu.querySelectorAll('a');
				links.forEach(link => {
					link.addEventListener('click', () => {
						if (isMenuOpen) toggleMenu();
					});
				});
			}
		</script>
	</body>
</html>

<style is:global>
	:root { 
		--font-sans: 'Plus Jakarta Sans', sans-serif; 
		--font-serif: 'Lora', serif; 
	}
	body { font-family: var(--font-sans); }
	h1, h2, h3, h4, h5, h6 { font-family: var(--font-serif); }
</style>